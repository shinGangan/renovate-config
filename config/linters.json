{
  "packageRules": [
    {
      "groupName": "ESLint config and plugin",
      "groupSlug": "linters",
      "matchPackageNames": [
        "@nuxt/eslint-config",
        "@intlify/eslint-plugin-vue-i18n",
        "@vitest/eslint-plugin"
      ],
      "matchPackagePrefixes": [
        "eslint",
        "markdownlint"
      ]
    }
  ]
}
